# === API Keys (至少配置一个 LLM Provider 的 Key) ===
GEMINI_API_KEY="在这里输入你的 Google Gemini API Key"
DEEPSEEK_API_KEY="在这里输入你的 DeepSeek API Key"
OPENROUTER_API_KEY="在这里输入你的 OpenRouter API Key"
THREEOTWO_API_KEY="在这里输入你的 302.ai API Key"

# === LLM 模型配置 ===
# 可选 Provider: gemini, deepseek, openrouter, 302ai
LLM_PROVIDER=gemini
# 模型标识符 (根据 Provider 不同需要填写不同的值)
# Gemini: gemini-3.1-pro-preview, gemini-3-flash-preview, gemini-2.5-pro, gemini-2.5-flash 等
# DeepSeek: deepseek-chat, deepseek-reasoner
# OpenRouter/302.ai: 直接填写模型名称字符串
LLM_MODEL=gemini-3.1-pro-preview

# === 图像生成模型配置 ===
# 可选 Provider: gemini
IMAGE_PROVIDER=gemini
# 模型: gemini-3.1-flash-image-preview, gemini-3-pro-image-preview, gemini-2.5-flash-image
IMAGE_MODEL=gemini-3.1-flash-image-preview

# === 数据存储 ===
DATA_DIR=data/projects

# === 自定义角色数据 ===
# 指定外部角色数据目录，可以放置自定义的角色 YAML 文件
# 目录结构与 internal/chardb/data/ 相同:
#   CHARDB_DIR/
#     my-series/
#       _series.yaml
#       character1.yaml
#       character2.yaml
# 留空则仅使用内置角色数据
CHARDB_DIR=

# === 自定义画风模板 ===
# 指定外部画风模板目录，可以放置自定义的画风配置和 Prompt 模板
# 目录结构:
#   STYLES_DIR/
#     my_style/
#       style.yaml       # 包含 name 和 description
#       draw.md.tmpl     # 具体画风的 Prompt 模板
# 留空则仅使用内置画风
STYLES_DIR=

# === HTTP 服务器 (仅 cmd/server 使用) ===
SERVER_ADDR=:8080
